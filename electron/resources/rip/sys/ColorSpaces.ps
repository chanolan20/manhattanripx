%!PS-Adobe-3.0
%%Title: CADlink Color Spaces
%%Creator: Manhattan RIP X
%%EndComments

% sRGB color space definition
/sRGBCS [
  /CIEBasedABC
  << /DecodeLMN [{dup 0.03928 le {12.92321 div}{0.055 add 1.055 div 2.4 exp} ifelse} bind dup dup]
     /MatrixLMN [0.4124 0.2126 0.0193 0.3576 0.7152 0.1192 0.1805 0.0722 0.9505]
     /WhitePoint [0.9505 1.0 0.9090]
  >>
] def

% CMYK color space
/CADlinkCMYK [/DeviceCMYK] def

% Gray color space  
/CADlinkGray [/DeviceGray] def

%%EOF
